<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Phase A LLM prototype keys (founder-local ONLY).

	  Setup:
	  1. Copy this file to LLMSecrets.plist in this same directory.
	  2. Paste your dedicated PROTOTYPE keys below (create them fresh in
	     each provider console; set hard spend limits there too).
	  3. LLMSecrets.plist is gitignored — never commit it, never
	     screenshot it, never paste keys anywhere else in the repo.

	  The file is bundled only into founder-local Debug builds by a
	  conditional build phase; missing file = LLM features report
	  notConfigured and the app runs on deterministic mocks.
	  Revoke these keys before any TestFlight or external distribution
	  (server-side proxy is the hard gate — see
	  docs/features/llm/TWINKO_LLM_PHASE_A.md).
	-->
	<key>ANTHROPIC_API_KEY</key>
	<string></string>
	<key>OPENAI_API_KEY</key>
	<string></string>
	<!--
	  Step 7 blind benchmark (optional, non-secret). The exact OpenAI
	  model id must be verified in the OpenAI console before running —
	  the live benchmark test skips while this is blank. The Anthropic
	  model defaults to claude-sonnet-5 when blank.
	-->
	<key>TAROT_BENCHMARK_OPENAI_MODEL</key>
	<string></string>
	<key>TAROT_BENCHMARK_ANTHROPIC_MODEL</key>
	<string></string>
	<!--
	  Normal live Tarot generation (step 10). With BOTH api keys
	  configured, TAROT_LIVE_PROVIDER ("anthropic" | "openai") is
	  REQUIRED - resolution fails closed to the labeled mock without
	  it. OpenAI additionally requires an explicit model id in
	  TAROT_LIVE_OPENAI_MODEL (never guessed; falls back to
	  TAROT_BENCHMARK_OPENAI_MODEL if that is set instead).
	  TAROT_LIVE_ANTHROPIC_MODEL is optional (defaults to
	  claude-sonnet-5).
	-->
	<key>TAROT_LIVE_PROVIDER</key>
	<string></string>
	<key>TAROT_LIVE_OPENAI_MODEL</key>
	<string></string>
	<key>TAROT_LIVE_ANTHROPIC_MODEL</key>
	<string></string>
</dict>
</plist>
